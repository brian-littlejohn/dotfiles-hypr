{
  "layer": "top",
  "position": "top",
  "height": 36,
  "spacing": 16,

  "modules-left": ["hyprland/workspaces"],
  "modules-center": ["network"],
  "modules-right": ["cpu", "memory", "wireplumber", "bluetooth", "battery", "clock", "tray"],

  "hyprland/workspaces": {
    "format": "{name}",
    "disable-scroll": true,
    "all-outputs": true
  },

  "clock": {
    "format": "{:%H:%M}",
    "tooltip-format": "{:%A, %d %B %Y}"
  },

  "network": {
    "format-wifi": "  {signalStrength}% | {ipaddr}",
    "format-ethernet": "󰈀 {ipaddr}",
    "format-disconnected": "  Offline"
  },

  "battery": {
    "format": "{capacity}%",
    "format-charging": " {capacity}%",
    "format-full": "  {capacity}%"
  },

  "cpu": {
    "format": "  {usage}% {avg_frequency}GHz",
    "intrval": 5
  },

  "memory": {
    "format": "  {percentage}%",
    "format-tooltip": "{used:0.1f}G/{total:0.1f}G ({percentage}%)",
    "interval": 10,
    "states": {
	"warning":70,
	"critical":90,
	},
  },

  "pulseaudio": {
        "scroll-step": 2,
        "format": "{icon} {volume}%",
        "format-muted":"󰝟 muted",
        "format-icons": {
            "headphones": "",
            "handsfree": "",
            "headset": "",
            "phone": "",
            "portable": "",
            "car": "",
            "default": ["󰕿", "󰖀", "󰕾"]
       },
        "on-click": "pavucontrol"
  },

  "bluetooth": {
	"on-click": "~/.config/waybar/scripts/rofi-bluetooth &",
	"format": " {status}",
  },


  "tray": {
    "spacing": 20
  },
  
  "wireplumber": {
    "format": "{icon} {volume}%",
    "format-muted": "🔇 {volume}%",
    "format-icons": {
        "default": ["🔈", "🔉", "🔊"],
        "muted": "🔇"
    },
    "tooltip": true,
    "on-click": "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle",
    "on-scroll-up": "wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%+",
    "on-scroll-down": "wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%-"
},



}
